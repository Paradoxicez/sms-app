{
  "name": "@sms-platform/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "prebuild": "prisma generate",
    "start": "nest start",
    "prestart": "prisma generate",
    "start:dev": "nest start --watch",
    "prestart:dev": "prisma generate",
    "start:prod": "node dist/main",
    "test": "vitest run --reporter=verbose",
    "pretest": "prisma generate && pnpm run db:test:setup",
    "db:test:setup": "bash scripts/setup-test-db.sh",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "psql $DATABASE_URL_MIGRATE -f src/prisma/migrations/camera_stream_url_unique/migration.sql && DATABASE_URL=$DATABASE_URL_MIGRATE prisma db push --accept-data-loss && psql $DATABASE_URL_MIGRATE -f src/prisma/migrations/camera_push_fields/migration.sql && psql $DATABASE_URL_MIGRATE -f src/prisma/migrations/recording_segment_has_keyframe/migration.sql && psql $DATABASE_URL_MIGRATE -f src/prisma/migrations/rls_apply_all/migration.sql && prisma generate",
    "db:push:skip-rls": "prisma db push && prisma generate"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.18",
    "@opentelemetry/api": "^1.9.1",
    "@prisma/client": "^6.19.3",
    "archiver": "^7.0.1",
    "better-auth": "^1.6.1",
    "bullmq": "^5.73.2",
    "csv-parse": "^6.2.1",
    "express": "^5.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.7",
    "nanoid": "^3.3.11",
    "nestjs-cls": "^6.2.0",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "zod": "^3.25.76"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "npx tsx src/prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.18",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@swc/register": "^0.1.10",
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "2",
    "ioredis-mock": "^8.13.1",
    "ts-node": "^10.9.0",
    "typescript": "~5.7.0",
    "vitest": "2"
  }
}
