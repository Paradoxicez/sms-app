# ============================================================================
# SMS Platform — production environment template
# Phase 26 (DEPLOY-22). Copy to deploy/.env and run deploy/scripts/init-secrets.sh
# to populate every `change-me-*` secret with a 32-byte base64-random value.
# Then edit DOMAIN and GHCR_ORG by hand. Final perms: 600 (set by init-secrets.sh).
#
# Compose entrypoint: docker compose -f deploy/docker-compose.yml --env-file deploy/.env up -d
# ============================================================================

# === Section 1: Required (no default) ===
# Public hostname for the deployment. Caddy auto-issues a Let's Encrypt cert
# for this name (Phase 27). Point an A-record at this server BEFORE first up.
DOMAIN=

# Postgres password used by the postgres container AND every service that
# reaches it via DATABASE_URL. 32+ char random. Generator: init-secrets.sh.
DB_PASSWORD=change-me-db-password

# Web-side Next.js auth secret (Better Auth client). 32+ char random.
NEXTAUTH_SECRET=change-me-nextauth-secret

# Server-side Better Auth secret (api). 32+ char random. MUST differ from
# NEXTAUTH_SECRET — different surfaces, different rotation cadence.
BETTER_AUTH_SECRET=change-me-better-auth-secret

# MinIO root password. 32+ char random. Used to bootstrap the avatars +
# recordings buckets and as fallback access key for the api.
MINIO_ROOT_PASSWORD=change-me-minio-root-password

# Playback session JWT signing secret (api). 32+ char random.
JWT_PLAYBACK_SECRET=change-me-jwt-playback-secret

# First super-admin user (Phase 29 bin/sms create-admin reads these on first run).
# Email format only validated at admin creation time.
ADMIN_EMAIL=
ADMIN_PASSWORD=change-me-admin-password

# === Section 2: Image refs ===
# GitHub org or user name that owns the GHCR images.
# Image refs resolve to: ghcr.io/${GHCR_ORG}/sms-{api,web}:${IMAGE_TAG}
GHCR_ORG=

# Image tag to pull. Pin a semver (e.g. v1.3.0) in production.
# `latest` is acceptable for dev/staging; surprising on prod (Pitfall 4 anti-pattern).
IMAGE_TAG=latest

# === Section 3: Defaults (override-only) ===
# Postgres credentials/DB name. Defaults match the v1.2 dev compose so existing
# tooling (CLAUDE.md Prisma workflow) Just Works on prod.
POSTGRES_USER=sms
POSTGRES_DB=sms_platform

# MinIO root username. Default `minioadmin` is acceptable — pair with a
# 32+ char MINIO_ROOT_PASSWORD (above) for security; see CONTEXT D-25.
MINIO_ROOT_USER=minioadmin

# Optional Redis password. Empty string means no auth (default; safe because
# the redis container lives on the internal:true network, not host-reachable).
REDIS_PASSWORD=

# === Section 4: Computed (derived — leave commented out unless overriding) ===
# These are normally derived inside the compose file from the values above.
# Uncomment + edit only if you need a non-default DSN (external Postgres, etc.).
# DATABASE_URL=postgresql://${POSTGRES_USER}:${DB_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public
# REDIS_URL=redis://redis:6379
# MINIO_ENDPOINT=minio
# MINIO_PORT=9000
# MINIO_USE_SSL=false
